# MongoDB Atlas or local mongodb:// connection string (required)
MONGODB_URI=

# Optional database name (defaults to "app")
# MONGODB_DB=app

# XRPL testnet wallets — for the hackathon all users share USER_WALLET_SEED.
# Generate with the Testnet faucet: https://xrpl.org/resources/dev-tools/xrp-faucets
USER_WALLET_SEED=
POT_WALLET_SEED=
XRPL_POT_WALLET_ADDRESS=

# Charity destination address. Failed stakes land here via EscrowFinish.
# Pick a separate testnet wallet so pot and charity are distinct on-chain.
XRPL_CHARITY_ADDRESS=

# Admin secret — required as the `x-admin-secret` header on destructive or
# admin-only endpoints (/api/goals/resolve, /api/goals/expire).
ADMIN_SECRET=

# Session secret — HMAC key used to sign login cookies. Must be >= 16 chars.
# Regenerate to force-logout all users.
SESSION_SECRET=

# Google AI Studio API key — enables the optional VLM (Gemma 4) check on
# proof uploads. Get one free at https://aistudio.google.com/app/apikey.
# If unset, proof verification still works (EXIF + GPS), the AI badge
# just won't appear.
GEMINI_API_KEY=

# Gemma model ID. Defaults to gemma-4-26b-a4b-it (fast MoE, 4B active).
# Swap to gemma-4-31b-it for higher quality at higher latency.
# GEMINI_VLM_MODEL=gemma-4-26b-a4b-it
